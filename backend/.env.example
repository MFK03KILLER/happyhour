NODE_ENV=development
PORT=4000
MONGO_URI=mongodb://localhost:27017/happyhour
JWT_ACCESS_SECRET=change_me_access_secret_demo_only
JWT_REFRESH_SECRET=change_me_refresh_secret_demo_only
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
ADMIN_EMAIL=admin@happyhour.demo
ADMIN_PASSWORD=Admin@12345
MOCK_PAYMENTS=true
QR_SIGNING_SECRET=change_me_qr_secret_demo_only
QR_TTL_SECONDS=60

# --- OAuth providers ---
# Google: Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID (type: Web).
# Paste the Client ID below (looks like 1234567890-xxxxxxxxxxxx.apps.googleusercontent.com).
# Add your customer-app origin to "Authorized JavaScript origins" (e.g. https://130.185.120.120:8443).
GOOGLE_CLIENT_ID=

# Apple: developer.apple.com -> Certificates, Identifiers & Profiles -> Identifiers
#   Services ID (e.g. com.happyhour.web) goes here. Configure Sign in with Apple on that Services ID.
#   Add your customer-app origin + return URL (e.g. https://130.185.120.120:8443/login).
APPLE_SERVICE_ID=
APPLE_TEAM_ID=
