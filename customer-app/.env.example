VITE_API_BASE=http://localhost:4000/api/v1

# --- OAuth (must match the values you used on the backend) ---
# Same Google Client ID you put in backend/.env (GOOGLE_CLIENT_ID).
VITE_GOOGLE_CLIENT_ID=

# Same Apple Services ID you put in backend/.env (APPLE_SERVICE_ID).
VITE_APPLE_SERVICE_ID=

# Where Apple should redirect after the popup auth completes.
# Must be added in your Apple Services ID's "Return URLs" field exactly.
VITE_APPLE_REDIRECT_URI=http://localhost:5173/login
