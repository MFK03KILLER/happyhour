# API base URL used ONLY for the native iOS build (npm run build:native).
# Apple's App Transport Security blocks plain http:// and raw IPs, so this MUST be
# an absolute HTTPS URL with a valid TLS certificate.
#
# Production backend (same server as the website; Nginx proxies /api/).
# NOTE: requires HTTPS to be live on the domain (run /root/enable-https.sh after DNS points to the server).
VITE_API_BASE=https://happyhourz.org/api/v1
