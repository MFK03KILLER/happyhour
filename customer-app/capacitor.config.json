{
  "appId": "app.happyhour.customer",
  "appName": "Happy Hour",
  "webDir": "dist",
  "ios": {
    "contentInset": "always"
  },
  "server": {
    "iosScheme": "capacitor"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor": "#0E5C5C",
      "showSpinner": false
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  }
}
