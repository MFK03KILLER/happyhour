# API base URL used ONLY for the native iOS build (npm run build:native).
# Apple's App Transport Security blocks plain http:// and raw IPs, so this MUST be
# an absolute HTTPS URL with a valid TLS certificate.
#
# >>> CHANGE THIS to your real backend domain before the production build. <<<
VITE_API_BASE=https://api.happyhour.app/api/v1
